[MAIN]
# Ignore optional dependencies not present in CI environment
ignored-modules=mayavi,mayavi.mlab,PyQt5

# Allow Pylint to see members of C-extension modules
extension-pkg-allow-list=numpy,scipy

# Allow N, X, Y, Z, M as valid variable names (math notation)
good-names=i,j,k,ex,Run,_,N,X,Y,Z,M,x,y,z,n,m,dim,h,u,v,w,R

[FORMAT]
max-line-length=88

[MESSAGES CONTROL]
# Disable specific warnings
disable=
    R0801, # duplicate-code (common in presentation/example scripts)
    C0103, # invalid-name
    R0913, # too-many-arguments
    R0914, # too-many-locals
    C0303, # trailing-whitespace (handled by ruff)

[DESIGN]
# Relax complexity limits for mathematically dense algorithms
max-branches=35
max-statements=90
max-positional-arguments=6
